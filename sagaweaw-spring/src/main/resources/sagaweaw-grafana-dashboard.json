{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource where Sagaweaw metrics are scraped",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "9.0.0" },
    { "type": "panel", "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel", "id": "bargauge",   "name": "Bar gauge",  "version": "" }
  ],
  "description": "Saga execution overview — success rate, throughput, latency, compensation, and outbox health. Import into any Grafana instance connected to Prometheus.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "tags": [],
      "title": "Sagaweaw Docs",
      "tooltip": "Sagaweaw documentation",
      "type": "link",
      "url": "https://doc.sagaweaw.dev"
    }
  ],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Sagas Started",
      "description": "Total sagas started in the selected time range",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(sagaweaw_sagas_started_total{saga=~\"$saga\"}[$__range]))",
          "legendFormat": "Started"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate",
      "description": "Percentage of sagas that completed successfully (last 5 minutes)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(sagaweaw_sagas_completed_total{saga=~\"$saga\"}[5m])) / (sum(rate(sagaweaw_sagas_completed_total{saga=~\"$saga\"}[5m])) + sum(rate(sagaweaw_sagas_failed_total{saga=~\"$saga\"}[5m])))",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 90   },
              { "color": "green",  "value": 99   }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Compensated",
      "description": "Sagas that triggered automatic compensation in the selected range",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(sagaweaw_sagas_compensated_total{saga=~\"$saga\"}[$__range]))",
          "legendFormat": "Compensated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1    },
              { "color": "red",    "value": 10   }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Outbox Pending",
      "description": "Messages waiting to be published to Kafka. Alert if this grows continuously.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sagaweaw_outbox_pending",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 10   },
              { "color": "red",    "value": 100  }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Saga Volume",
      "description": "Rate of sagas started, completed, failed, and compensated per minute",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sagaweaw_sagas_started_total{saga=~\"$saga\"}[1m])) by (saga)",
          "legendFormat": "Started — {{saga}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate(sagaweaw_sagas_completed_total{saga=~\"$saga\"}[1m])) by (saga)",
          "legendFormat": "Completed — {{saga}}"
        },
        {
          "refId": "C",
          "expr": "sum(rate(sagaweaw_sagas_failed_total{saga=~\"$saga\"}[1m])) by (saga)",
          "legendFormat": "Failed — {{saga}}"
        },
        {
          "refId": "D",
          "expr": "sum(rate(sagaweaw_sagas_compensated_total{saga=~\"$saga\"}[1m])) by (saga)",
          "legendFormat": "Compensated — {{saga}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Saga Duration — P50 / P95",
      "description": "Median and 95th-percentile end-to-end saga duration in milliseconds",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(sagaweaw_sagas_duration_seconds_bucket{saga=~\"$saga\"}[5m])) by (le, saga)) * 1000",
          "legendFormat": "P50 — {{saga}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(sagaweaw_sagas_duration_seconds_bucket{saga=~\"$saga\"}[5m])) by (le, saga)) * 1000",
          "legendFormat": "P95 — {{saga}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 7,
      "type": "bargauge",
      "title": "Step Bottleneck — P95 Duration",
      "description": "Which step is slowest? 95th-percentile execution time per step name.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(histogram_quantile(0.95, sum(rate(sagaweaw_steps_duration_seconds_bucket[5m])) by (le, step)) * 1000)",
          "legendFormat": "{{step}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "orange", "value": 1000  },
              { "color": "red",    "value": 5000  }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      }
    },

    {
      "id": 8,
      "type": "bargauge",
      "title": "Step Failure Rate",
      "description": "Which step fails most often? Failures per second per step name.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(sum(rate(sagaweaw_steps_failed_total[5m])) by (step))",
          "legendFormat": "{{step}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null   },
              { "color": "orange", "value": 0.001  },
              { "color": "red",    "value": 0.01   }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      }
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sagaweaw", "java", "spring-boot", "microservices", "saga-pattern"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(sagaweaw_sagas_started_total, saga)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Saga",
        "multi": true,
        "name": "saga",
        "query": {
          "query": "label_values(sagaweaw_sagas_started_total, saga)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Sagaweaw — Saga Observability",
  "uid": "sagaweaw-overview",
  "version": 1
}
